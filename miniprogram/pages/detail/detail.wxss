/* detail.wxss - 深色主题，与网页版统一 */
/* 移除备案信息样式（小程序独立备案） */

page {
  background: #000000;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #FFFFFF;
}

.container {
  padding: 16px;
  min-height: 100vh;
  box-sizing: border-box;
  max-width: 600px;
  margin: 0 auto;
  background: #000000;
}

/* 顶部导航 */
.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.back-btn {
  font-size: 16px;
  color: #007AFF;
  padding: 8px 0;
}

.tab-switch {
  display: flex;
  gap: 8px;
}

.tab-btn {
  padding: 6px 12px;
  font-size: 14px;
  color: #8E8E93;
  background: #2C2C2E;
  border-radius: 16px;
}

.tab-btn.active {
  background: #007AFF;
  color: #fff;
}

.close-tab-btn {
  font-size: 14px;
  color: #007AFF;
  padding: 8px 0;
  margin-bottom: 12px;
}

/* 卡片 */
.card {
  background: linear-gradient(145deg, rgba(35,35,40,0.95) 0%, rgba(22,22,25,0.98) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #FFFFFF;
}

/* 股票信息 */
.stock-info {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.stock-code {
  font-size: 18px;
  font-weight: 600;
  color: #007AFF;
}

.stock-name {
  font-size: 16px;
  color: #AEAEB2;
}

.score-large {
  text-align: center;
}

.score-number {
  font-size: 48px;
  font-weight: 700;
}

.score-number.excellent { color: #FF3B30; }
.score-number.good { color: #FF9500; }
.score-number.poor { color: #34C759; }
.score-number.negative { color: #FF3B30; }

.score-label {
  font-size: 14px;
  color: #8E8E93;
  margin-top: 4px;
}

.score-max {
  font-size: 12px;
  color: #636366;
  margin-top: 4px;
}

.updated-time {
  font-size: 12px;
  color: #8E8E93;
  margin-top: 8px;
}

/* 季度选择器 */
.quarter-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.quarter-tab {
  flex: 1;
  padding: 10px 0;
  text-align: center;
  background: #2C2C2E;
  border-radius: 8px;
  font-size: 14px;
  color: #8E8E93;
}

.quarter-tab.active {
  background: #007AFF;
  color: #FFFFFF;
  font-weight: 600;
}

.quarter-date {
  display: block;
  font-size: 11px;
  opacity: 0.8;
  margin-top: 2px;
}

/* 进度条 */
.progress-item {
  margin-bottom: 12px;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: #AEAEB2;
  margin-bottom: 6px;
}

.progress-bar {
  height: 8px;
  background: #2C2C2E;
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s ease;
}

.progress-fill.excellent { background: #FF3B30; }
.progress-fill.good { background: #FF9500; }
.progress-fill.poor { background: #34C759; }

/* 财务数据网格 */
.finance-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.finance-item {
  background: #2C2C2E;
  border-radius: 8px;
  padding: 12px;
}

.finance-label {
  font-size: 12px;
  color: #8E8E93;
  margin-bottom: 4px;
}

.finance-value {
  font-size: 14px;
  color: #FFFFFF;
}

.finance-value.growth-up { color: #FF3B30; }
.finance-value.growth-down { color: #34C759; }

/* 翻转动画 */
.flip-container {
  margin-bottom: 12px;
  position: relative;
  height: 280px;
}

.flip-front,
.flip-back {
  backface-visibility: hidden;
  transition: transform 0.5s ease;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280px;
  box-sizing: border-box;
}

.flip-front {
  transform: rotateY(0deg);
}

.flip-container.flipped .flip-front {
  transform: rotateY(-180deg);
}

.flip-container.flipped .flip-back {
  transform: rotateY(0deg);
}

/* K线卡片 */
.kline-card {
  padding: 16px;
  background: linear-gradient(145deg, rgba(35,35,40,0.95) 0%, rgba(22,22,25,0.98) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
}

.kline-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.kline-title {
  font-size: 15px;
  font-weight: 600;
  color: #007AFF;
}

.kline-type {
  color: #007AFF;
  background: rgba(0, 122, 255, 0.1);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.kline-loading,
.kline-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 180px;
  color: #8E8E93;
  font-size: 14px;
}

.kline-error {
  color: #FF3B30;
}

.kline-wrapper {
  position: relative;
}

.kline-date {
  font-size: 12px;
  color: #8E8E93;
  margin-bottom: 8px;
}

.kline-canvas {
  width: 100%;
  height: 180px;
}

.trend-canvas {
  width: 100%;
  height: 200px;
}

.kline-tooltip {
  position: absolute;
  background: rgba(28, 28, 30, 0.95);
  border: 1px solid #38383A;
  border-radius: 8px;
  padding: 8px 12px;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.kline-tooltip text {
  font-size: 11px;
  color: #fff;
  line-height: 1.5;
}

.kline-tooltip .tooltip-date {
  font-weight: 600;
  margin-bottom: 2px;
}

.kline-stats {
  margin-top: 12px;
  font-size: 12px;
  color: #8E8E93;
  text-align: center;
}

.kline-stats .up,
.up {
  color: #ef232a;
}

.kline-stats .down,
.down {
  color: #14b143;
}

.toggle-btn {
  margin-bottom: 12px;
  background: #2C2C2E;
  color: #AEAEB2;
  border: 1px solid #38383A;
}

/* 趋势解读 */
.insight {
  background: #2C2C2E;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 8px;
}

.insight-text {
  font-size: 14px;
  color: #AEAEB2;
  line-height: 1.5;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40px 0;
  color: #8E8E93;
}

.spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #38383A;
  border-top-color: #007AFF;
  border-radius: 50%;
  margin: 0 auto 12px;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 错误 */
.error {
  background: rgba(255,59,48,0.15);
  color: #FF3B30;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 14px;
}

/* 评分说明/反馈卡片 */
.info-card {
  background: linear-gradient(145deg, rgba(35,35,40,0.95) 0%, rgba(22,22,25,0.98) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.info-title {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16px;
}

.info-section {
  margin-bottom: 16px;
}

.info-subtitle {
  font-size: 15px;
  font-weight: 600;
  color: #AEAEB2;
  margin-bottom: 8px;
}

.info-table {
  border: 1px solid #38383A;
  border-radius: 8px;
  overflow: hidden;
}

.info-row {
  display: flex;
  padding: 10px 12px;
  border-bottom: 1px solid #38383A;
  font-size: 14px;
  color: #AEAEB2;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.header {
  background: #3A3A3C;
  font-weight: 600;
  color: #8E8E93;
}

.info-row text {
  flex: 1;
  text-align: center;
}

.info-row text:first-child {
  text-align: left;
}

.info-note {
  font-size: 12px;
  color: #8E8E93;
  margin-top: 8px;
}

.info-text {
  font-size: 14px;
  color: #8E8E93;
  line-height: 1.6;
}

/* 反馈表单 */
.feedback-form {
  margin: 16px 0;
}

.feedback-textarea {
  width: 100%;
  height: 120px;
  padding: 12px;
  border: 1px solid #38383A;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  background: #2C2C2E;
  color: #FFFFFF;
}

.feedback-btn {
  padding: 10px 24px;
  border-radius: 20px;
  font-size: 14px;
  border: none;
}

.feedback-btn.submit {
  background: #007AFF;
  color: #fff;
}

.feedback-btn[disabled] {
  opacity: 0.5;
}

.feedback-message {
  margin-top: 12px;
  padding: 10px;
  border-radius: 8px;
  font-size: 14px;
  text-align: center;
}

.feedback-message.success {
  background: rgba(52,199,89,0.15);
  color: #34C759;
}

.feedback-message.error {
  background: rgba(255,59,48,0.15);
  color: #FF3B30;
}

/* 多因子系统入口 */
.footer-link {
  text-align: center;
  padding: 16px 0;
  font-size: 14px;
  color: #007AFF;
}