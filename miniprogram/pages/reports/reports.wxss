/* reports.wxss - 深色主题，与网页版统一 */
page {
  background: #000000;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #FFFFFF;
}

.container {
  min-height: 100vh;
  max-width: 600px;
  margin: 0 auto;
  padding: 0 20px 40px;
  box-sizing: border-box;
  background: #000000;
}

/* Header */
.header {
  background: linear-gradient(180deg, rgba(35,35,40,0.95) 0%, rgba(22,22,25,0.98) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 24px 20px;
  margin: 16px 0;
  text-align: center;
}

.title {
  font-size: 20px;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  font-size: 13px;
  opacity: 0.8;
}

/* 搜索框 */
.search-box {
  background: linear-gradient(145deg, rgba(60,60,65,0.8) 0%, rgba(35,35,40,0.9) 100%);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 14px 18px;
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  color: #FFFFFF;
  font-size: 15px;
  outline: none;
}

.search-input::placeholder {
  color: #8E8E93;
}

.search-btn {
  background: linear-gradient(180deg, rgba(90,90,95,0.95) 0%, rgba(50,50,55,0.95) 100%);
  border: 1px solid rgba(255,255,255,0.12);
  color: #FFFFFF;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 14px;
}

/* 搜索结果 */
.search-results {
  background: rgba(30,30,35,0.98);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 10px 16px;
  margin-bottom: 12px;
}

.search-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #38383A;
}

.search-item:last-child {
  border-bottom: none;
}

.item-code {
  width: 80px;
  color: #007AFF;
  font-weight: 600;
  font-size: 14px;
}

.item-name {
  flex: 1;
  color: #AEAEB2;
  font-size: 14px;
}

.item-score {
  font-weight: 600;
  font-size: 14px;
}

/* 加载和错误 */
.loading, .error {
  padding: 40px 20px;
  text-align: center;
  color: #8E8E93;
}

.error {
  color: #FF3B30;
}

/* 卡片 */
.section {
  background: linear-gradient(145deg, rgba(35,35,40,0.95) 0%, rgba(22,22,25,0.98) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 12px;
}

.stitle {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid #38383A;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 16px;
}

.stat-card {
  background: #2C2C2E;
  border-radius: 12px;
  padding: 12px 8px;
  text-align: center;
}

.stat-value {
  font-size: 18px;
  font-weight: 700;
  color: #007AFF;
  display: block;
}

.stat-label {
  font-size: 10px;
  color: #8E8E93;
  margin-top: 4px;
  display: block;
}

/* 评分分布条 */
.dist-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 6px 0;
  font-size: 12px;
}

.dist-label {
  width: 55px;
  color: #8E8E93;
  font-size: 11px;
}

.dist-bar-bg {
  flex: 1;
  height: 16px;
  background: #2C2C2E;
  border-radius: 3px;
  overflow: hidden;
}

.dist-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 3px;
}

.dist-value {
  width: 85px;
  color: #8E8E93;
  text-align: right;
  font-size: 11px;
}

/* 榜单列表 */
.rank-list {
  margin-top: 12px;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #38383A;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 36px;
  font-weight: 600;
  color: #007AFF;
  font-size: 14px;
}

.rank-code {
  width: 70px;
  color: #007AFF;
  font-size: 13px;
}

.rank-name {
  flex: 1;
  color: #AEAEB2;
  font-size: 13px;
}

.rank-score {
  font-weight: 600;
  text-align: right;
  font-size: 14px;
}

/* 冠军列表 */
.champion-list {
  margin-top: 12px;
}

.champion-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #38383A;
  font-size: 12px;
}

.champion-item:last-child {
  border-bottom: none;
}

.champion-factor {
  width: 90px;
  color: #007AFF;
  font-weight: 600;
  font-size: 12px;
}

.champion-code {
  width: 60px;
  color: #AEAEB2;
  font-size: 12px;
}

.champion-name {
  flex: 1;
  color: #8E8E93;
  font-size: 12px;
}

.champion-score {
  color: #34C759;
  font-weight: 600;
  font-size: 12px;
}

/* 描述文本 */
.section-desc {
  font-size: 12px;
  color: #8E8E93;
  margin-bottom: 10px;
}

/* 特别关注股票卡片 */
.focus-card {
  background: #2C2C2E;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.focus-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.focus-code {
  font-size: 15px;
  font-weight: 700;
  color: #007AFF;
}

.focus-name {
  font-size: 13px;
  color: #8E8E93;
}

.focus-score {
  font-size: 24px;
  font-weight: 700;
  color: #007AFF;
  text-align: center;
  display: block;
  margin: 8px 0;
}

/* 因子表格 */
.factor-table {
  font-size: 11px;
  margin-top: 10px;
}

.factor-header {
  display: flex;
  background: #38383A;
  padding: 6px 8px;
  font-weight: 600;
  color: #8E8E93;
  border-radius: 6px 6px 0 0;
}

.factor-header text {
  flex: 1;
}

.factor-row {
  display: flex;
  padding: 6px 8px;
  border-bottom: 1px solid #38383A;
  color: #AEAEB2;
}

.factor-row:last-child {
  border-bottom: none;
}

.factor-name {
  flex: 1;
}

.factor-val {
  flex: 1;
  text-align: center;
}

.factor-change {
  flex: 1;
  text-align: center;
}

.factor-status {
  flex: 1;
  text-align: right;
}

/* 历史走势 */
.history-trend {
  margin-top: 10px;
  font-size: 11px;
  line-height: 1.8;
  color: #8E8E93;
}

.trend-title {
  font-weight: 600;
  color: #AEAEB2;
}

.trend-item {
  display: block;
}

.trend-total {
  display: block;
  margin-top: 4px;
  color: #AEAEB2;
}

.rank-info {
  font-size: 11px;
  color: #8E8E93;
  margin-top: 8px;
  display: block;
}

/* 诊断 */
.diagnosis {
  margin-top: 8px;
  font-size: 11px;
  line-height: 1.6;
}

.diagnosis text {
  display: block;
  margin-top: 4px;
}

/* 评分颜色 */
.gs { color: #34C759; }  /* 高分-绿 */
.gm { color: #FF9500; }  /* 中分-橙 */
.gb { color: #FF3B30; }  /* 低分-红 */
.sg { background: rgba(52,199,89,0.15); color: #34C759; padding: 2px 6px; border-radius: 6px; font-size: 10px; }
.sm { background: rgba(255,149,0,0.15); color: #FF9500; padding: 2px 6px; border-radius: 6px; font-size: 10px; }
.sb { background: rgba(255,59,48,0.15); color: #FF3B30; padding: 2px 6px; border-radius: 6px; font-size: 10px; }